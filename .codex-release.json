{
  "schemaVersion": 1,
  "projectName": "CopyShare",
  "branch": "main",
  "remote": "origin",
  "remoteUrlPattern": "github\\.com[:/]suzeccc/Copy-share(?:\\.git)?$",
  "tagPrefix": "v",
  "version": {
    "read": {
      "path": "package.json",
      "pattern": "\"version\"\\s*:\\s*\"(?<version>\\d+\\.\\d+\\.\\d+)\""
    },
    "updates": [
      {
        "path": "package.json",
        "pattern": "(\"version\"\\s*:\\s*\")\\d+\\.\\d+\\.\\d+(\")",
        "replacement": "${1}{version}$2",
        "expectedMatches": 1
      },
      {
        "path": "package-lock.json",
        "pattern": "(?s)^(\\{\\s*\"name\"\\s*:\\s*\"copyshare\"\\s*,\\s*\"version\"\\s*:\\s*\")\\d+\\.\\d+\\.\\d+(\")",
        "replacement": "${1}{version}$2",
        "expectedMatches": 1
      },
      {
        "path": "package-lock.json",
        "pattern": "(?s)(\"packages\"\\s*:\\s*\\{\\s*\"\"\\s*:\\s*\\{\\s*\"name\"\\s*:\\s*\"copyshare\"\\s*,\\s*\"version\"\\s*:\\s*\")\\d+\\.\\d+\\.\\d+(\")",
        "replacement": "${1}{version}$2",
        "expectedMatches": 1
      },
      {
        "path": "src-tauri/Cargo.toml",
        "pattern": "(?m)^version = \"\\d+\\.\\d+\\.\\d+\"$",
        "replacement": "version = \"{version}\"",
        "expectedMatches": 1
      },
      {
        "path": "src-tauri/Cargo.lock",
        "pattern": "(?s)(\\[\\[package\\]\\]\\s+name = \"copyshare\"\\s+version = \")\\d+\\.\\d+\\.\\d+(\")",
        "replacement": "${1}{version}$2",
        "expectedMatches": 1
      },
      {
        "path": "src-tauri/tauri.conf.json",
        "pattern": "(\"version\"\\s*:\\s*\")\\d+\\.\\d+\\.\\d+(\")",
        "replacement": "${1}{version}$2",
        "expectedMatches": 1
      },
      {
        "path": "tests/versionConsistency.test.ts",
        "pattern": "const expectedVersion = \"\\d+\\.\\d+\\.\\d+\";",
        "replacement": "const expectedVersion = \"{version}\";",
        "expectedMatches": 1
      },
      {
        "path": ".github/workflows/release.yml",
        "pattern": "(?m)^\\s*default: v\\d+\\.\\d+\\.\\d+$",
        "replacement": "        default: {tag}",
        "expectedMatches": 1
      }
    ]
  },
  "prepare": {
    "parallel": true,
    "localOutputDirectory": "output",
    "commands": [
      {
        "name": "Node tests",
        "command": "node --test tests/*.test.ts"
      },
      {
        "name": "Tauri executable build",
        "command": "npm run build:exe"
      }
    ],
    "artifacts": [
      {
        "source": "src-tauri/target/release/CopyShare.exe",
        "destination": "output/CopyShare.exe",
        "localName": "CopyShare.exe",
        "verifyWindowsVersion": true,
        "sha256": true
      }
    ]
  },
  "releaseNotes": {
    "heading": "## 更新内容",
    "minItems": 2,
    "maxItems": 6,
    "requireChinese": true
  },
  "publish": {
    "workflow": {
      "name": "Release",
      "event": "push",
      "findTimeoutSeconds": 120,
      "waitTimeoutMinutes": 90
    },
    "release": {
      "mode": "publish-draft",
      "title": "{projectName} {tag}",
      "requireDraft": true,
      "requiredAssets": [
        {
          "pattern": "(?i)x64-setup\\.exe$",
          "label": "Windows x64 NSIS"
        },
        {
          "pattern": "(?i)(arm64|aarch64)-setup\\.exe$",
          "label": "Windows ARM64 NSIS"
        },
        {
          "pattern": "(?i)aarch64\\.dmg$",
          "label": "macOS Apple Silicon DMG"
        },
        {
          "pattern": "(?i)x64\\.dmg$",
          "label": "macOS Intel DMG"
        },
        {
          "pattern": "(?i)\\.(AppImage|deb|rpm)$",
          "label": "Linux bundle"
        }
      ]
    }
  }
}
