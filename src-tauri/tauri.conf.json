{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copy-Sharer",
  "version": "2.0.0",
  "identifier": "com.copysharer.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Copy-Sharer",
        "width": 1120,
        "height": 720,
        "center": true,
        "minWidth": 960,
        "minHeight": 620,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
